# =============================================================================
# AOIX-1 Local Development Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# Database Connection (MySQL/TiDB). Optional for local dev: omit or comment out to run without DB (auth uses in-memory user).
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/aoix1

# JWT Secret (generate a random string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-change-this-to-a-random-string

# OAuth Configuration (provided by Manus)
VITE_APP_ID=your_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# Owner Information
OWNER_NAME=Your Name
OWNER_OPEN_ID=your_open_id

# Forge API Configuration (provided by Manus)
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your_frontend_key

# Interactive Brokers — Client Portal Gateway (REST API)
# Default port 5000: run Gateway, then open http://localhost:5000 to log in.
# Use 4001 only if you run TWS/IB Gateway on that port instead.
TWS_HOST=localhost
TWS_PORT=5000
# If Connect fails with 401: log in at http://localhost:5000, copy the "api" cookie from DevTools → Application → Cookies → localhost:5000, then set:
# IB_GATEWAY_COOKIE=api=YOUR_COPIED_VALUE

# Application Configuration
VITE_APP_TITLE=AOIX-1
VITE_APP_LOGO=/logo.png

# Server Port (optional, defaults to 3000)
PORT=3000

# Optional: Polygon.io API Key (for market data fallback)
# POLYGON_API_KEY=your_polygon_key_optional

# Anthropic Claude API (for trade validation in Catalyst layer)
# Get key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# -----------------------------------------------------------------------------
# Optional: Blueprint 10/10 (turn on only after validation)
# -----------------------------------------------------------------------------
# Position sizing × intent.confidence. Turn on only after 100–150 trades confirm calibration.
# ENABLE_CONFIDENCE_SIZING=false

# Outcome store: "memory" (default), "file", or "sqlite".
# Use "file" or "sqlite" so the system learns from trades (calibration every 50 outcomes).
# - file: no DB, writes to ./data/outcomes.jsonl (set OUTCOME_FILE for custom path).
# - sqlite: requires optional dep better-sqlite3, writes to ./data/trade_outcomes.sqlite.
# OUTCOME_STORE=file

# Confidence calibration every 50 trades. Turn on after you have persistent outcome store (file or sqlite).
# ENABLE_CONFIDENCE_CALIBRATION=false
