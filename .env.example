# AOIX-1 TRADING SYSTEM ENVIRONMENT CONFIGURATION

# ============================================================================
# TRADING MODE
# ============================================================================
# Set to 'false' for PAPER TRADING (safe, recommended for testing)
# Set to 'true' for LIVE TRADING (real money, real risk)
ENABLE_LIVE_TRADING=false

# ============================================================================
# IBKR GATEWAY CONFIGURATION
# ============================================================================
# Host of IBKR Gateway (usually localhost if running locally)
IBKR_HOST=localhost

# Port of IBKR Gateway (default 5000)
IBKR_PORT=5000

# IBKR Account ID (e.g., "DU1234567" or leave empty for paper)
IBKR_ACCOUNT_ID=

# IBKR Session Token
# How to get: 
# 1. Start IBKR Gateway
# 2. Log in at https://localhost:5000/web
# 3. Copy the session token
# 4. Paste here
IBKR_SESSION_TOKEN=

# ============================================================================
# TRADING PARAMETERS
# ============================================================================
# How often to scan for opportunities (milliseconds)
# 5000 = every 5 seconds (recommended)
SCAN_INTERVAL_MS=5000

# Maximum concurrent positions
# 3 = no more than 3 trades open at once
MAX_POSITIONS=3

# Maximum risk per trade (0.01 = 1%)
# Never risk more than 1% per trade
MAX_RISK_PER_TRADE=0.01

# Symbols to trade (comma-separated)
# Add more symbols to expand universe
TRADING_SYMBOLS=SPY,QQQ,AAPL,NVDA,TSLA,META,AMD,MSFT,NFLX,GOOGL

# ============================================================================
# LOGGING
# ============================================================================
# Directory for trade logs and session records
LOG_DIR=./logs

# ============================================================================
# DATABASE (If needed later)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/aoix
# DATABASE_URL=mysql://user:password@localhost:3306/aoix

# ============================================================================
# API KEYS (Reserved for future integrations)
# ============================================================================
# CEREBRAS_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# ============================================================================
# ADVANCED OPTIONS (Leave as default unless you know what you're doing)
# ============================================================================
# JWT Secret for session management
JWT_SECRET=aoix-trading-system-secret-2026

# Admin password for dashboard
ADMIN_SECRET=change-me-in-production

# Node environment
NODE_ENV=production
